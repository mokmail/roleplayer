type RelationshipCategoryId = typeof RELATIONSHIP_CATEGORIES[number]['id'];

type LayoutAlgorithm = 'force' | 'circular' | 'hierarchical' | 'grid' | 'cluster';
type ViewMode = 'all' | 'active' | 'public' | 'private' | 'secret';

